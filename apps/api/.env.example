APP_NAME=DocFlow AI API
APP_VERSION=0.2.0
DATABASE_URL=postgresql+psycopg://docflow:docflow@localhost:5432/docflow
UPLOAD_DIR=./storage/uploads
AUTO_CREATE_TABLES=false
LLM_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
EXECUTION_BACKEND=inline
REDIS_URL=redis://localhost:6379/0
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_SECONDS=5
DEAD_LETTER_DIR=./storage/dead_letter
OPS_API_TOKEN=
REVIEW_MIN_LENGTH=120
REVIEW_LENGTH_PENALTY=20
REVIEW_TODO_PENALTY=15
REVIEW_REQUIRED_KEYWORDS=summary,conclusion
REVIEW_KEYWORD_PENALTY=8
REVIEW_REQUIRED_THRESHOLD=90

# Telegram — single-bot mode (PM bot handles inbound + outbound fallback)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# Telegram — multi-bot identity mode (Phase 1.5)
# 각 역할 에이전트마다 별도 봇 토큰을 설정하면 해당 봇이 메시지를 발송합니다.
# 설정하지 않으면 TELEGRAM_BOT_TOKEN(PM) 봇이 fallback으로 사용됩니다.
TELEGRAM_PM_BOT_TOKEN=        # planner, reviewer, manager 역할 담당
TELEGRAM_WRITER_BOT_TOKEN=    # writer 역할 담당
TELEGRAM_CRITIC_BOT_TOKEN=    # critic 역할 담당
TELEGRAM_CODER_BOT_TOKEN=     # coder 역할 담당

# Orchestrator
AGENT_CONFIG_PATH=./config/agents.yaml
ORCHESTRATOR_DEFAULT_MODE=pipeline
ORCHESTRATOR_MAX_TURNS=6
ORCHESTRATOR_AUTO_SUMMARY=true
