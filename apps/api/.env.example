DATABASE_URL=sqlite:///storage/db/docflow.db
AUTO_CREATE_TABLES=false
LLM_PROVIDER=stub

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Optional per-agent overrides
# Format: AGENT_<HANDLE>_PROVIDER / AGENT_<HANDLE>_MODEL
# Supported providers: stub, openai, anthropic, ollama
#
# Examples
# AGENT_PLANNER_PROVIDER=openai
# AGENT_PLANNER_MODEL=${OPENAI_MODEL}
# AGENT_WRITER_PROVIDER=anthropic
# AGENT_WRITER_MODEL=${ANTHROPIC_MODEL}
# AGENT_CRITIC_PROVIDER=anthropic
# AGENT_CRITIC_MODEL=${ANTHROPIC_MODEL}
# AGENT_QA_PROVIDER=anthropic
# AGENT_QA_MODEL=${ANTHROPIC_MODEL}
# AGENT_MANAGER_PROVIDER=openai
# AGENT_MANAGER_MODEL=${OPENAI_MODEL}
